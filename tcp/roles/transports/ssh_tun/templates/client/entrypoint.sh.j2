#!/bin/sh
set -eu

: "${NETWORK_VPN_INTERFACE:?}"
: "${NETWORK_VPN_SERVER_IPV4:?}"
: "${NETWORK_VPN_GATEWAY_IPV4:=10.11.12.1}"
: "${NETWORK_VPN_CLIENT_CIDR_IPV4:=10.11.12.2/30}"
: "${NETWORK_VPN_MTU:=1200}"

configure_dns() {
    cat > /etc/resolv.conf <<RESOLV
nameserver ${NETWORK_VPN_GATEWAY_IPV4}
options timeout:1 attempts:2 ndots:0
RESOLV
}

detect_host_route() {
    network_host_gateway_interface="$(ip route get "$NETWORK_VPN_SERVER_IPV4" 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i == "dev") {print $(i+1); exit}}')"
    network_host_gateway_ipv4="$(ip route get "$NETWORK_VPN_SERVER_IPV4" 2>/dev/null | awk '{for (i=1; i<=NF; i++) if ($i == "via") {print $(i+1); exit}}')"

    if [ -z "${network_host_gateway_interface:-}" ] || [ -z "${network_host_gateway_ipv4:-}" ]; then
        network_host_gateway_interface="$(ip -br addr | awk '$1 !~ /^(lo|tun|docker|veth|vir)/ && $2 ~ /UP/ {print $1; exit}')"
        if [ -n "${network_host_gateway_interface:-}" ]; then
            network_host_gateway_ipv4="$(ip route | awk -v dev="$network_host_gateway_interface" '$0 ~ dev && $1 != "default" {print $1; exit}' | sed 's#\.[0-9]\+/.*#.1#')"
        fi
    fi

    [ -n "${network_host_gateway_interface:-}" ] && [ -n "${network_host_gateway_ipv4:-}" ]
}

setup_tun() {
    detect_host_route || {
        return 1
    }

    cleanup_tun
    ip route replace "$NETWORK_VPN_SERVER_IPV4" via "$network_host_gateway_ipv4" dev "$network_host_gateway_interface"
    ip tuntap add mode tun user root name "$NETWORK_VPN_INTERFACE" >/dev/null 2>&1 || true
    ip addr flush dev "$NETWORK_VPN_INTERFACE" >/dev/null 2>&1 || true
    ip addr add "$NETWORK_VPN_CLIENT_CIDR_IPV4" peer "$NETWORK_VPN_GATEWAY_IPV4" dev "$NETWORK_VPN_INTERFACE"
    ip link set dev "$NETWORK_VPN_INTERFACE" up mtu "$NETWORK_VPN_MTU"
    ip route del default >/dev/null 2>&1 || true
    ip route add default via "$NETWORK_VPN_GATEWAY_IPV4" dev "$NETWORK_VPN_INTERFACE" metric 50
    configure_dns
}

cleanup_tun() {
    ip route del default >/dev/null 2>&1 || true
    ip addr flush dev "$NETWORK_VPN_INTERFACE" >/dev/null 2>&1 || true
    ip link set dev "$NETWORK_VPN_INTERFACE" down >/dev/null 2>&1 || true
}

setup_tun
exec ssh -N -F /ssh/config proxy
