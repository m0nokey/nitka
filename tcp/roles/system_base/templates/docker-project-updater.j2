#!/bin/bash
set -Eeuo pipefail
IFS=$'\n\t'

compose_file="{{ system_base_docker_updater_compose_file }}"
compose_proj="{{ system_base_docker_updater_name }}"
health_timeout="{{ system_base_docker_updater_health_timeout }}"

log_i() { printf "\033[1;34m[INFO]\033[0m %s\n" "$*"; }
log_e() { printf "\033[1;31m[ERR]\033[0m %s\n" "$*" >&2; }
die() { log_e "$*"; exit 1; }
need_cmd() { command -v "$1" >/dev/null 2>&1 || die "missing command: $1"; }

compose_config() {
    docker compose -f "$compose_file" -p "$compose_proj" config
}

get_image_of_service() {
    local svc="$1"
    compose_config | awk -v svc="$svc" '$0 ~ ("^[[:space:]]*" svc ":") { f=1; next } f && $1=="image:" { print $2; exit }'
}

current_ctr_image_id() {
    local ctr="$1"
    docker inspect -f '{% raw %}{{.Image}}{% endraw %}' "$ctr" 2>/dev/null || true
}

img_changed() {
    local cur="$1" new="$2"
    if [[ -n "$cur" && -n "$new" && "$cur" == "$new" ]]; then
        echo 0
    else
        echo 1
    fi
}

wait_health() {
    local name="$1" timeout="${2:-120}" id hs run i
    for ((i=0; i<timeout; i++)); do
        id="$(docker ps --filter "name=^${name}$" --format '{% raw %}{{.ID}}{% endraw %}' | head -n1)"
        if [[ -n "$id" ]]; then
            hs="$(docker inspect -f '{% raw %}{{if .State.Health}}{{.State.Health.Status}}{{else}}{{""}}{{end}}{% endraw %}' "$id" 2>/dev/null || true)"
            run="$(docker inspect -f '{% raw %}{{.State.Running}}{% endraw %}' "$id" 2>/dev/null || true)"
            if [[ "$hs" == "healthy" || ( -z "$hs" && "$run" == "true" ) ]]; then
                return 0
            fi
        fi
        sleep 1
    done
    return 1
}

prune_repo_unused() {
    local repo="$1" keep_ref="$2"
    docker images --format '{% raw %}{{.Repository}}:{{.Tag}}{% endraw %}' \
    | awk -v r="^${repo}:" '$0 ~ r {print}' \
    | while read -r ref; do
        [[ "$ref" == "$keep_ref" ]] && continue
        if ! docker ps -aq --filter "ancestor=$ref" | grep -q .; then
            docker rmi -f "$ref" >/dev/null 2>&1 || true
        fi
    done
}

backup_lines=()

add_backup_line() {
    local svc="$1" repo_tag="$2" old_id="$3"
    [[ -n "$old_id" ]] && backup_lines+=( "${svc}|${repo_tag}|${old_id}" )
}

rollback_to_backups() {
    if [[ -z "${backup_lines[*]:-}" ]]; then
        log_e "no backups captured; cannot rollback"
        return 1
    fi

    log_i "retagging previous images to original repo:tag..."
    local line svc repo_tag old_id
    for line in "${backup_lines[@]}"; do
        IFS='|' read -r svc repo_tag old_id <<<"$line"
        if docker image inspect "$old_id" >/dev/null 2>&1; then
            docker image tag "$old_id" "$repo_tag" || true
        else
            log_e "backup image missing for ${svc} (${old_id}); skipping retag"
        fi
    done

    log_i "rolling back production..."
    docker compose -f "$compose_file" -p "$compose_proj" up -d --force-recreate
    wait_all_services || true
    log_i "rollback complete."
}

service_names=(
{% for service in system_base_docker_updater_services %}
    "{{ service.service }}"
{% endfor %}
)

container_names=(
{% for service in system_base_docker_updater_services %}
    "{{ service.container }}"
{% endfor %}
)

image_types=(
{% for service in system_base_docker_updater_services %}
    "{{ service.image_type }}"
{% endfor %}
)

base_images=(
{% for service in system_base_docker_updater_services %}
    "{{ service.base_image | default('') }}"
{% endfor %}
)

external_images=(
{% for service in system_base_docker_updater_services %}
    "{{ service.image | default('') }}"
{% endfor %}
)

release_repos=(
{% for service in system_base_docker_updater_services %}
    "{{ service.release_repo | default('') }}"
{% endfor %}
)

release_image_templates=(
{% for service in system_base_docker_updater_services %}
    "{{ service.release_image_template | default('') }}"
{% endfor %}
)

cascade_restarts=(
{% for service in system_base_docker_updater_services %}
    "{{ service.cascade_restart | default([]) | join(' ') }}"
{% endfor %}
)

changed=()

mark_changed() {
    local idx="$1"
    changed[$idx]=1
}

service_index() {
    local needle="$1" i
    for i in "${!service_names[@]}"; do
        if [[ "${service_names[$i]}" == "$needle" ]]; then
            echo "$i"
            return 0
        fi
    done
    return 1
}

wait_all_services() {
    local i
    for i in "${!container_names[@]}"; do
        wait_health "${container_names[$i]}" "$health_timeout" || return 1
    done
}

latest_semver_release() {
    local repo="$1"
    curl -fsSL --connect-timeout 10 --max-time 30 \
        "https://api.github.com/repos/${repo}/releases/latest" \
    | sed -nE 's/.*"tag_name"[[:space:]]*:[[:space:]]*"(v[0-9]+\.[0-9]+\.[0-9]+)".*/\1/p'
}

release_image_ref() {
    local template="$1" tag="$2" tag_no_v
    if [[ "$template" != *'{tag}'* && "$template" != *'{tag_no_v}'* ]]; then
        printf '%s' "$template"
        return 0
    fi
    tag_no_v="${tag#v}"
    printf '%s' "$template" | sed "s/{tag_no_v}/${tag_no_v}/g; s/{tag}/${tag}/g"
}

need_cmd docker
need_cmd awk
need_cmd curl
need_cmd flock
need_cmd grep
need_cmd sed

[[ -f "$compose_file" ]] || die "compose file not found: $compose_file"
docker compose -f "$compose_file" -p "$compose_proj" config -q >/dev/null || die "compose syntax error"

exec 9>/run/{{ system_base_docker_updater_name }}-docker-updater.lock
if ! flock -n 9; then
    log_i "another update run is in progress, exiting"
    exit 0
fi

log_i "resolving images from compose..."
for i in "${!service_names[@]}"; do
    changed[$i]=0
    svc="${service_names[$i]}"
    typ="${image_types[$i]}"
    ref="$(get_image_of_service "$svc")"
    [[ -n "$ref" ]] || die "image for service $svc not found"

    if [[ "$typ" == "external" ]]; then
        before="$(docker image inspect -f '{% raw %}{{.Id}}{% endraw %}' "$ref" 2>/dev/null || true)"
        pull_ref="${external_images[$i]:-$ref}"
        if [[ -n "${release_repos[$i]}" && -n "${release_image_templates[$i]}" ]]; then
            if [[ "${release_image_templates[$i]}" == *'{tag}'* || "${release_image_templates[$i]}" == *'{tag_no_v}'* ]]; then
                release_tag="$(latest_semver_release "${release_repos[$i]}")"
                [[ -n "$release_tag" ]] || die "could not resolve latest release for ${release_repos[$i]}"
                pull_ref="$(release_image_ref "${release_image_templates[$i]}" "$release_tag")"
                log_i "resolved ${svc} latest release ${release_tag}: ${pull_ref}"
            else
                pull_ref="${release_image_templates[$i]}"
                log_i "using static release image for ${svc}: ${pull_ref}"
            fi
        fi
        log_i "pulling ${pull_ref}..."
        docker pull "$pull_ref" >/dev/null 2>&1 || true
        if [[ "$pull_ref" != "$ref" ]]; then
            docker image tag "$pull_ref" "$ref"
        fi
        after="$(docker image inspect -f '{% raw %}{{.Id}}{% endraw %}' "$ref" 2>/dev/null || true)"
        [[ -z "$before" || -z "$after" || "$before" != "$after" ]] && mark_changed "$i"
    elif [[ "$typ" == "build" ]]; then
        base="${base_images[$i]}"
        if [[ -n "$base" ]]; then
            old_base="$(docker image inspect -f '{% raw %}{{.Id}}{% endraw %}' "$base" 2>/dev/null || true)"
            log_i "pulling base image ${base}..."
            docker pull "$base" >/dev/null 2>&1 || true
            new_base="$(docker image inspect -f '{% raw %}{{.Id}}{% endraw %}' "$base" 2>/dev/null || true)"
            [[ -z "$old_base" || -z "$new_base" || "$old_base" != "$new_base" ]] && mark_changed "$i"
        fi

        if ! docker image inspect "$ref" >/dev/null 2>&1; then
            mark_changed "$i"
        fi

        if [[ "${changed[$i]}" -eq 1 ]]; then
            log_i "building ${svc} (${ref})..."
            docker compose -f "$compose_file" -p "$compose_proj" build --pull --no-cache "$svc"
        fi
    else
        die "unknown image_type for $svc: $typ"
    fi
done

for i in "${!service_names[@]}"; do
    if [[ "${changed[$i]}" -eq 1 && -n "${cascade_restarts[$i]}" ]]; then
        for cascade_service in ${cascade_restarts[$i]}; do
            cascade_idx="$(service_index "$cascade_service" || true)"
            if [[ -n "$cascade_idx" ]]; then
                log_i "marking ${cascade_service} for recreate because ${service_names[$i]} changed"
                mark_changed "$cascade_idx"
            fi
        done
    fi
done

any_changed=0
for i in "${!service_names[@]}"; do
    svc="${service_names[$i]}"
    ref="$(get_image_of_service "$svc")"
    new_id="$(docker image inspect -f '{% raw %}{{.Id}}{% endraw %}' "$ref" 2>/dev/null || true)"
    cur_id="$(current_ctr_image_id "${container_names[$i]}")"
    if [[ "$(img_changed "$cur_id" "$new_id")" -eq 1 || "${changed[$i]}" -eq 1 ]]; then
        changed[$i]=1
        any_changed=1
        [[ -n "$cur_id" ]] && add_backup_line "$svc" "$ref" "$cur_id"
    fi
done

for i in "${!service_names[@]}"; do
    if [[ "${changed[$i]}" -eq 1 && -n "${cascade_restarts[$i]}" ]]; then
        for cascade_service in ${cascade_restarts[$i]}; do
            cascade_idx="$(service_index "$cascade_service" || true)"
            if [[ -n "$cascade_idx" && "${changed[$cascade_idx]}" -eq 0 ]]; then
                log_i "marking ${cascade_service} for recreate because ${service_names[$i]} changed"
                mark_changed "$cascade_idx"
                any_changed=1
            fi
        done
    fi
done

if [[ "$any_changed" -eq 0 ]]; then
    log_i "images unchanged; nothing to do"
    exit 0
fi

log_i "rolling production..."
for i in "${!service_names[@]}"; do
    if [[ "${changed[$i]}" -eq 1 ]]; then
        svc="${service_names[$i]}"
        ctr="${container_names[$i]}"
        log_i "recreating ${svc}..."
        docker compose -f "$compose_file" -p "$compose_proj" up -d --no-deps --no-build --force-recreate "$svc"
        if ! wait_health "$ctr" "$health_timeout"; then
            log_e "${svc} unhealthy after rollout - rolling back"
            rollback_to_backups || true
            exit 1
        fi
    fi
done

log_i "verifying all updater-managed services..."
if ! wait_all_services; then
    log_e "one or more services unhealthy after rollout - rolling back"
    rollback_to_backups || true
    exit 1
fi

for i in "${!service_names[@]}"; do
    ref="$(get_image_of_service "${service_names[$i]}")"
    repo="${ref%:*}"
    prune_repo_unused "$repo" "$ref"
done

docker image prune -f >/dev/null 2>&1 || true
docker builder prune -f --filter 'until={{ system_base_docker_updater_prune_builder_until }}' >/dev/null 2>&1 || true

log_i "update complete."
