#!/bin/sh
set -eu

compose_dir="{{ ingress_remote_dir }}"
ssh_container="ssh_tun_client"
clash_container="clashrs"
xray_container="xray"
clash_port="{{ ingress_clash_port }}"
check_interval="{{ ingress_watchdog_interval_seconds | default(30) }}"

log() {
    logger -t nitka-ingress-watchdog "$*"
}

is_running() {
    [ "$(docker inspect -f '{% raw %}{{.State.Running}}{% endraw %}' "$1" 2>/dev/null || true)" = "true" ]
}

health_status() {
    docker inspect -f '{% raw %}{{if .State.Health}}{{.State.Health.Status}}{{else}}none{{end}}{% endraw %}' "$1" 2>/dev/null || true
}

container_netns() {
    docker exec "$1" readlink /proc/1/ns/net 2>/dev/null || true
}

recreate_dependents() {
    reason="$1"
    log "recreating clashrs and xray: ${reason}"
    cd "$compose_dir"
    docker rm -f clashrs xray >/dev/null 2>&1 || true
    docker compose up -d --force-recreate --no-deps clashrs xray >/dev/null
}

check_once() {
    if ! is_running "$ssh_container"; then
        log "${ssh_container} is not running; waiting for Docker restart policy"
        return 0
    fi

    ssh_health="$(health_status "$ssh_container")"
    if [ "$ssh_health" != "healthy" ]; then
        log "${ssh_container} health is ${ssh_health}; waiting for it to become healthy"
        return 0
    fi

    if ! is_running "$clash_container"; then
        recreate_dependents "${clash_container} is not running"
        return 0
    fi

    ssh_netns="$(container_netns "$ssh_container")"
    clash_netns="$(container_netns "$clash_container")"

    if [ -z "$ssh_netns" ] || [ -z "$clash_netns" ]; then
        recreate_dependents "failed to read network namespace"
        return 0
    fi

    if [ "$ssh_netns" != "$clash_netns" ]; then
        recreate_dependents "network namespace mismatch ssh=${ssh_netns} clash=${clash_netns}"
        return 0
    fi

    if ! docker exec "$ssh_container" sh -c "ss -ltn 2>/dev/null | grep -q '[.:]${clash_port} '" >/dev/null 2>&1; then
        recreate_dependents "clash socks port ${clash_port} is not listening in ssh namespace"
        return 0
    fi

    clash_health="$(health_status "$clash_container")"
    if [ "$clash_health" != "healthy" ]; then
        recreate_dependents "${clash_container} health is ${clash_health}"
        return 0
    fi

    if ! is_running "$xray_container"; then
        cd "$compose_dir"
        log "${xray_container} is not running; starting it"
        docker compose up -d xray >/dev/null
    fi
}

run_loop() {
    while :; do
        if ! check_once; then
            log "watchdog check failed"
        fi
        sleep "$check_interval"
    done
}

case "${1:---loop}" in
    --once)
        check_once
        ;;
    --loop)
        run_loop
        ;;
    *)
        echo "usage: $0 [--once|--loop]" >&2
        exit 2
        ;;
esac
