name: nitka-ingress

services:
  ssh_tun_client:
    container_name: nitka-ssh-tun-client
    build:
      context: ./ssh_tun_client
    image: local/ssh-tun-client:latest
    env_file:
      - ./ssh_tun_client/security.env
    cap_drop:
      - ALL
    cap_add:
      - NET_ADMIN
      - NET_RAW
      - SYS_ADMIN
    security_opt:
      - no-new-privileges:true
    devices:
      - /dev/net/tun:/dev/net/tun
    restart: unless-stopped
    healthcheck:
      test: ["CMD", "/usr/local/bin/healthcheck"]
      interval: {{ ingress_ssh_healthcheck_interval | default('5s') }}
      timeout: {{ ingress_ssh_healthcheck_timeout | default('2s') }}
      retries: {{ ingress_ssh_healthcheck_retries | default(2) }}
      start_period: {{ ingress_ssh_healthcheck_start_period | default('5s') }}
    volumes:
      - ./ssh_tun_client:/ssh:ro
    dns:
      - {{ ssh_tun_network_vpn_gateway_ipv4 }}
    dns_search: []
    networks:
      - nitka_ingress
    tmpfs:
      - /tmp:rw,noexec,nosuid,nodev,size=32m,mode=1777
    pids_limit: 100
    mem_limit: 128m
    memswap_limit: 128m
    cpus: 0.50
    logging:
      driver: none

  clashrs:
    container_name: nitka-clashrs
    image: local/clash-rs:latest
    network_mode: "service:ssh_tun_client"
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    init: true
    depends_on:
      ssh_tun_client:
        condition: service_healthy
    restart: unless-stopped
    volumes:
      - ./clashrs/config.yaml:/etc/clash/config.yaml:ro
    command: ["-d", "/etc/clash", "--compatibility"]
    healthcheck:
      test: ["CMD", "nc", "-z", "-w", "2", "127.0.0.1", "{{ ingress_clash_port }}"]
      interval: {{ ingress_clash_healthcheck_interval | default('5s') }}
      timeout: {{ ingress_clash_healthcheck_timeout | default('2s') }}
      retries: {{ ingress_clash_healthcheck_retries | default(2) }}
      start_period: {{ ingress_clash_healthcheck_start_period | default('5s') }}
    dns_search: []
    tmpfs:
      - /tmp:rw,noexec,nosuid,nodev,size=32m,mode=1777
    pids_limit: 100
    mem_limit: 256m
    memswap_limit: 256m
    cpus: 0.50
    logging:
      driver: none

  xray:
    container_name: nitka-xray
    image: local/xray-core:auto
    cap_drop:
      - ALL
    security_opt:
      - no-new-privileges:true
    init: true
    depends_on:
      clashrs:
        condition: service_healthy
    restart: unless-stopped
    volumes:
      - ./xray/config.json:/etc/xray/config.json:ro
    command: ["run", "-c", "/etc/xray/config.json"]
    ports:
      - "{{ ingress_xray_xhttp_port }}:{{ ingress_xray_xhttp_port }}"
      - "{{ ingress_xray_reality_port }}:{{ ingress_xray_reality_port }}"
    networks:
      - nitka_ingress
    dns_search: []
    tmpfs:
      - /tmp:rw,noexec,nosuid,nodev,size=32m,mode=1777
    pids_limit: 150
    mem_limit: 256m
    memswap_limit: 256m
    cpus: 0.75
    logging:
      driver: none

networks:
  nitka_ingress:
    name: nitka_ingress
    driver: bridge
