FROM alpine:3.23

ENV TZ=UTC

RUN apk add --no-cache \
      bind-tools \
      ca-certificates \
      tzdata \
      unbound && \
    cp /usr/share/zoneinfo/UTC /etc/localtime && \
    echo "UTC" > /etc/timezone

RUN install -d -m 0750 -o unbound -g unbound /var/lib/unbound && \
    unbound-anchor -v -a /var/lib/unbound/root.key || true && \
    test -s /var/lib/unbound/root.key && \
    cp /var/lib/unbound/root.key /tmp/root.key && \
    install -D -m 0644 -o unbound -g unbound /tmp/root.key /var/lib/unbound/root.key && \
    rm -f /tmp/root.key && \
    install -d -m 0755 -o root -g root /etc/unbound/unbound.conf.d && \
    install -d -m 0750 -o unbound -g unbound /var/lib/unbound/rpz && \
    install -d -m 0750 -o unbound -g unbound /run/unbound

COPY unbound.conf /tmp/unbound.conf
COPY unbound.conf.d/ /tmp/unbound.conf.d/

RUN install -D -m 0644 -o root -g root /tmp/unbound.conf /etc/unbound/unbound.conf && \
    for conf in /tmp/unbound.conf.d/*.conf; do \
      install -D -m 0644 -o root -g root "$conf" "/etc/unbound/unbound.conf.d/$(basename "$conf")"; \
    done && \
    rm -rf /tmp/unbound.conf /tmp/unbound.conf.d

RUN install -D -m 0755 -o root -g root /dev/stdin /usr/local/bin/healthcheck <<'EOS'
#!/bin/sh
unbound-control -c /etc/unbound/unbound.conf status >/dev/null 2>&1 || exit 1
exit 0
EOS

CMD ["unbound", "-d", "-c", "/etc/unbound/unbound.conf"]
